    <!-- About Us Activity -->
    <string name="about_us">Sobre nosotros</string>
    <string name="about_us_title">Equipo Buge Studio</string>
    <string name="about_us_description">El equipo de Buge Studio es un grupo apasionado de desarrolladores y diseñadores dedicados a crear aplicaciones utilitarias innovadoras y prácticas para la plataforma Android. Nos centramos en la privacidad del usuario, el control del sistema y la apertura. Nuestro objetivo es proporcionar a los usuarios herramientas transparentes, eficientes y fiables. Buge App Manager es un proyecto de código abierto y es nuestra primera aplicación importante. Invitamos a todos a participar en su mejora y desarrollo conjunto.</string>

    <!-- GMS Disable Warning -->
    <string name="gms_disable_warning_title">¿Desactivar los servicios de Google?</string>
    <string name="gms_disable_warning_message">Desactivar los servicios de Google afectará a lo siguiente:\n\n• Google Play Store dejará de funcionar\n• Las aplicaciones que dependen de Google Play Services pueden fallar\n• Las notificaciones push de las aplicaciones de Google se detendrán\n• Los servicios de ubicación pueden verse afectados\n• Las compras dentro de la aplicación no funcionarán\n\n¿Estás seguro de que quieres desactivar los servicios de Google?</string>

