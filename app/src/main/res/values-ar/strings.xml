    <!-- About Us Activity -->
    <string name="about_us">من نحن</string>
    <string name="about_us_title">فريق Buge Studio</string>
    <string name="about_us_description">فريق Buge Studio هو مجموعة شغوفة من المطورين والمصممين المكرسين لإنشاء تطبيقات أدوات عملية مبتكرة لنظام Android. نحن نركز على خصوصية المستخدم والتحكم في النظام والانفتاح. هدفنا هو توفير أدوات شفافة وفعالة وموثوقة للمستخدمين. مدير تطبيقات Buge هو مشروع مفتوح المصدر، وهو أول تطبيق رئيسي لدينا. نرحب بالجميع للمشاركة في تحسينه وتطويره معًا.</string>

    <!-- GMS Disable Warning -->
    <string name="gms_disable_warning_title">تعطيل خدمات Google؟</string>
    <string name="gms_disable_warning_message">سيؤدي تعطيل خدمات Google إلى التأثير على ما يلي:\n\n• سيتوقف متجر Google Play عن العمل\n• قد تتعطل التطبيقات التي تعتمد على خدمات Google Play\n• ستتوقف إشعارات تطبيقات Google\n• قد تتأثر خدمات الموقع\n• لن تعمل عمليات الشراء داخل التطبيق\n\nهل أنت متأكد من رغبتك في تعطيل خدمات Google؟</string>

