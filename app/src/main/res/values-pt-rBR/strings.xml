    <!-- About Us Activity -->
    <string name="about_us">Sobre Nós</string>
    <string name="about_us_title">Equipe Buge Studio</string>
    <string name="about_us_description">A Equipe Buge Studio é um grupo apaixonado de desenvolvedores e designers dedicados a criar aplicativos utilitários inovadores e práticos para a plataforma Android. Focamos na privacidade do usuário, controle do sistema e abertura. Nosso objetivo é fornecer aos usuários ferramentas transparentes, eficientes e confiáveis. O Buge App Manager é um projeto de código aberto e é nosso primeiro aplicativo principal. Convidamos todos a participar de sua melhoria e desenvolvimento conjunto.</string>

    <!-- GMS Disable Warning -->
    <string name="gms_disable_warning_title">Desativar os Serviços Google?</string>
    <string name="gms_disable_warning_message">Desativar os Serviços Google afetará o seguinte:\n\n• A Google Play Store deixará de funcionar\n• Os aplicativos que dependem dos Serviços Google Play podem falhar\n• As notificações push dos aplicativos Google vão parar\n• Os serviços de localização podem ser afetados\n• As compras no aplicativo não funcionarão\n\nTem certeza de que deseja desativar os Serviços Google?</string>

