    <!-- About Us Activity -->
    <string name="about_us">关于我们</string>
    <string name="about_us_title">Buge Studio团队</string>
    <string name="about_us_description">Buge Studio团队是一群充满热情的开发者和设计师，致力于为Android平台创建创新实用的工具应用。我们专注于用户隐私、系统控制和开放性。我们的目标是为用户提供透明、高效、可靠的工具。Buge应用管理器是一个开源项目，也是我们的第一个主要应用。欢迎大家共同参与改进和开发。</string>

    <!-- GMS Disable Warning -->
    <string name="gms_disable_warning_title">禁用Google服务？</string>
    <string name="gms_disable_warning_message">禁用Google服务将影响以下功能：\n\n• Google Play商店将停止工作\n• 依赖Google Play服务的应用可能崩溃\n• Google应用的通知将停止\n• 位置服务可能受影响\n• 应用内购买将无法使用\n\n确定要禁用Google服务吗？</string>

