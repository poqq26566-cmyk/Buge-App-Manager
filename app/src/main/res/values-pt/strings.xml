    <!-- About Us Activity -->
    <string name="about_us">Sobre Nós</string>
    <string name="about_us_title">Equipa Buge Studio</string>
    <string name="about_us_description">A Equipa Buge Studio é um grupo apaixonado de programadores e designers dedicados a criar aplicações utilitárias inovadoras e práticas para a plataforma Android. Focamo-nos na privacidade do utilizador, controlo do sistema e abertura. O nosso objetivo é fornecer aos utilizadores ferramentas transparentes, eficientes e fiáveis. O Buge App Manager é um projeto de código aberto e é a nossa primeira aplicação principal. Convidamos todos a participar na sua melhoria e desenvolvimento conjunto.</string>

    <!-- GMS Disable Warning -->
    <string name="gms_disable_warning_title">Desativar os Serviços Google?</string>
    <string name="gms_disable_warning_message">Desativar os Serviços Google afetará o seguinte:\n\n• A Google Play Store deixará de funcionar\n• As aplicações que dependem dos Serviços Google Play podem falhar\n• As notificações push das aplicações Google vão parar\n• Os serviços de localização podem ser afetados\n• As compras na aplicação não funcionarão\n\nTem a certeza de que pretende desativar os Serviços Google?</string>

