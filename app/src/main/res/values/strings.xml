    <!-- About Us Activity -->
    <string name="about_us">About Us</string>
    <string name="about_us_title">Buge Studio Team</string>
    <string name="about_us_description">Buge Studio Team is a passionate group of developers and designers dedicated to creating innovative and practical utility applications for the Android platform. We focus on user privacy, system control, and openness. Our goal is to provide users with transparent, efficient, and reliable tools. Buge App Manager is an open-source project, and it is our first major application. We welcome everyone to participate in its improvement and development together.</string>
