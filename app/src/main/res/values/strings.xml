    <!-- GMS Disable Warning -->
    <string name="gms_disable_warning_title">Disable Google Services?</string>
    <string name="gms_disable_warning_message">Disabling Google Services will affect the following:\n\n• Google Play Store will stop working\n• Apps that rely on Google Play Services may crash\n• Push notifications from Google apps will stop\n• Location services may be affected\n• In-app purchases will not work\n\nAre you sure you want to disable Google Services?</string>

