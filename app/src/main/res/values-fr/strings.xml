    <!-- About Us Activity -->
    <string name="about_us">À propos de nous</string>
    <string name="about_us_title">Équipe Buge Studio</string>
    <string name="about_us_description">L\'équipe Buge Studio est un groupe passionné de développeurs et de designers dédiés à la création d\'applications utilitaires innovantes et pratiques pour la plateforme Android. Nous nous concentrons sur la confidentialité des utilisateurs, le contrôle du système et l\'ouverture. Notre objectif est de fournir aux utilisateurs des outils transparents, efficaces et fiables. Le Gestionnaire d\'applications Buge est un projet open source et c\'est notre première application majeure. Nous invitons tout le monde à participer à son amélioration et à son développement.</string>

    <!-- GMS Disable Warning -->
    <string name="gms_disable_warning_title">Désactiver les services Google ?</string>
    <string name="gms_disable_warning_message">La désactivation des services Google affectera les éléments suivants :\n\n• Le Google Play Store cessera de fonctionner\n• Les applications qui dépendent des services Google Play peuvent planter\n• Les notifications push des applications Google cesseront\n• Les services de localisation peuvent être affectés\n• Les achats intégrés ne fonctionneront pas\n\nÊtes-vous sûr de vouloir désactiver les services Google ?</string>

    <!-- System Operation Blocked -->
    <string name="system_op_blocked_title">Opération bloquée</string>
