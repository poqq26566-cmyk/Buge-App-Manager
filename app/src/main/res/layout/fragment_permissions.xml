<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/title_permissions" />

        <HorizontalScrollView
            android:id="@+id/permission_scroll_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:clipToPadding="false"
            android:paddingVertical="8dp">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/permission_chip_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_mic"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/perm_microphone"
                    app:chipIcon="@drawable/ic_mic"
                    android:checked="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_camera"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/perm_camera"
                    app:chipIcon="@drawable/ic_camera" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_location"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/perm_location"
                    app:chipIcon="@drawable/ic_location" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_contacts"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/perm_contacts" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_storage"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/perm_storage" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_manage_storage"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/perm_manage_storage" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_phone"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/perm_phone" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_sms"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/perm_sms" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_calendar"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/perm_calendar" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_sensors"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/perm_body_sensors" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_notifications"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/perm_notifications" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_overlay"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/perm_overlay" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_install_unknown"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/perm_install_unknown" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_write_settings"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/perm_write_settings"
                    app:chipIcon="@drawable/ic_settings" />

            </com.google.android.material.chip.ChipGroup>

        </HorizontalScrollView>

    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Batch Action Bar -->
        <LinearLayout
            android:id="@+id/batch_action_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/selected_count_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="14sp"
                style="@style/TextAppearance.Material3.LabelLarge" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_batch_revoke"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/batch_revoke"
                android:layout_marginEnd="8dp"
                android:paddingHorizontal="12dp"
                android:minWidth="0dp"
                android:singleLine="true"
                android:maxLines="1"
                android:ellipsize="end"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_batch_grant"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/batch_grant"
                android:paddingHorizontal="12dp"
                android:minWidth="0dp"
                android:singleLine="true"
                android:maxLines="1"
                android:ellipsize="end"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Loading Overlay -->
        <FrameLayout
            android:id="@+id/loading_overlay"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone"
            android:background="?attr/colorSurface">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/progress_bar"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:indeterminate="true"
                app:indicatorColor="?attr/colorPrimary"
                app:trackThickness="4dp"
                app:indicatorSize="48dp"
                app:indicatorDirectionCircular="clockwise" />

        </FrameLayout>

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/empty_state"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_security"
                android:alpha="0.3" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No apps with this permission"
                android:layout_marginTop="16dp"
                style="@style/TextAppearance.Material3.BodyLarge"
                android:alpha="0.5" />

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="80dp"
            android:visibility="visible" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>